server:
  http_listen_port: 9080
  grpc_listen_port: 0

positions:
  filename: /tmp/positions.yaml

clients:
  - url: http://{{ groups['loghost'][0] }}:3100/loki/api/v1/push

scrape_configs:
  - job_name: proseo_logs
    pipeline_stages:
      - drop:
          expression: '(?i)debug|trace'

    static_configs:
      - targets:
          - localhost
        labels:
          job: proseo
          host: {{ groups['nfsserver'][0] }}
          __path__: /opt/prosEO/log/**/*.log